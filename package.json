{
  "name": "zending-3d-editor",
  "productName": "ZENDING 3D EDITOR",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "node scripts/dev-electron.mjs",
    "demo:mqtt:generic:scene": "node scripts/create-generic-mqtt-motion-demo.mjs",
    "demo:stacker:scene": "node scripts/create-stacker-mqtt-demo-scene.mjs",
    "demo:stacker:mqtt": "node scripts/simulate-stacker-mqtt.mjs",
    "refresh:model-assets": "node scripts/refresh-model-asset-index.mjs",
    "wait:renderer": "node scripts/wait-for-vite-renderer.mjs",
    "build": "tsc -b && vite build && npm run build:viewer && npm run build:electron",
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "build:electron": "tsc -p tsconfig.node.json",
    "build:yzj:visual": "node scripts/build-yzj-direction-arrow-visual.mjs",
    "typecheck": "tsc -b",
    "preview": "vite preview --host 127.0.0.1",
    "test:telemetry": "node scripts/telemetry-test.mjs",
    "test:model-array": "node scripts/model-array-test.mjs",
    "smoke:units": "node scripts/smoke-meter-unit-contract.mjs && npm run smoke:cad && npm run smoke:model-measurement && npm run smoke:model-array && npm run smoke:model-parameters",
    "smoke:cad": "node scripts/smoke-cad-geometry-fidelity.mjs",
    "smoke:model-measurement": "node scripts/smoke-model-measurement.mjs",
    "smoke:model-array": "node scripts/smoke-model-array.mjs",
    "smoke:hierarchy-clipboard": "node scripts/smoke-hierarchy-clipboard.mjs",
    "smoke:model-parameters": "node scripts/smoke-model-parameter-meters.mjs",
    "smoke:shelf-instancing": "node scripts/smoke-shelf-shared-instancing.mjs",
    "smoke:scene-capacity": "node scripts/smoke-static-model-instancing-policy.mjs && node scripts/smoke-asset-load-scheduler.mjs && node scripts/smoke-scene-capacity.mjs",
    "smoke:gpu": "npm run build && node scripts/smoke-gpu-acceleration.mjs",
    "pack:win": "npm run build && electron-builder --win dir --x64",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "smoke:packaged:win": "node scripts/smoke-packaged-windows.mjs",
    "smoke:packaged:gpu": "node scripts/smoke-packaged-gpu.mjs",
    "smoke:installer:gpu": "npm run dist:win && npm run smoke:packaged:gpu",
    "smoke:data-platform": "node scripts/smoke-data-platform-project.mjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.0",
    "@babylonjs/loaders": "^9.12.0",
    "@linkiez/dxf-renew": "^7.4.5",
    "archiver": "^8.0.0",
    "mqtt": "^5.15.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unzipper": "^0.12.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "description": "面向工业场景搭建、模型参数化与 MQTT 运行预览的 Babylon.js 桌面编辑器。",
  "build": {
    "appId": "com.babylon3d.editor",
    "electronDist": "node_modules/electron/dist",
    "afterPack": "scripts/after-pack-clean-electron-dist.mjs",
    "copyright": "Copyright © 2026 ZENDING 3D EDITOR",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-viewer-template",
        "to": "export-viewer",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ZENDING-3D-EDITOR-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZENDING 3D EDITOR",
      "uninstallDisplayName": "ZENDING 3D EDITOR",
      "deleteAppDataOnUninstall": false
    }
  }
}
