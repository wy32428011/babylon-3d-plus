{
  "name": "babylon-electron-unity-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "node scripts/dev-electron.mjs",
    "demo:stacker:scene": "node scripts/create-stacker-mqtt-demo-scene.mjs",
    "demo:stacker:mqtt": "node scripts/simulate-stacker-mqtt.mjs",
    "wait:renderer": "node scripts/wait-for-vite-renderer.mjs",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.node.json",
    "typecheck": "tsc -b",
    "preview": "vite preview --host 127.0.0.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.0",
    "@babylonjs/loaders": "^9.12.0",
    "@linkiez/dxf-renew": "^7.4.5",
    "mqtt": "^5.15.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
