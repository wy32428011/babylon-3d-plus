{
  "lengthUnit": "meter",
  "parameterScripts": [
    {
      "fields": [
        {
          "key": "deviceName",
          "label": "显示名称",
          "defaultValue": "参数链路示例机柜"
        }
      ]
    }
  ],
  "modelParameters": {
    "schema": "babylon-editor.model-parameters",
    "version": 1,
    "parameters": [
      {
        "key": "bodyColor",
        "label": "主体颜色",
        "type": "color",
        "defaultValue": "#2f86ff"
      },
      {
        "key": "cabinetHeight",
        "label": "主体高度",
        "type": "number",
        "defaultValue": 1.2,
        "min": 0.6,
        "max": 2.2,
        "step": 0.1,
        "unit": "m"
      },
      {
        "key": "showAccentPanel",
        "label": "显示侧边面板",
        "type": "boolean",
        "defaultValue": true
      },
      {
        "key": "screenTexture",
        "label": "屏幕贴图",
        "type": "texture",
        "defaultValue": "textures/screen-grid.png",
        "allowedExtensions": [
          ".png"
        ],
        "options": [
          {
            "value": "textures/screen-grid.png",
            "label": "蓝色网格"
          },
          {
            "value": "textures/screen-stripes.png",
            "label": "黄色斜纹"
          }
        ]
      }
    ],
    "bindings": [
      {
        "target": {
          "kind": "material",
          "name": "BodyMaterial"
        },
        "property": "baseColor",
        "value": {
          "param": "bodyColor"
        }
      },
      {
        "target": {
          "kind": "mesh",
          "name": "Body"
        },
        "property": "scaling",
        "value": {
          "vector3": [
            1,
            {
              "param": "cabinetHeight"
            },
            1
          ]
        }
      },
      {
        "target": {
          "kind": "mesh",
          "name": "AccentPanel"
        },
        "property": "visible",
        "value": {
          "param": "showAccentPanel"
        }
      },
      {
        "target": {
          "kind": "material",
          "name": "ScreenMaterial"
        },
        "property": "baseTexture",
        "value": {
          "param": "screenTexture"
        }
      }
    ]
  },
  "displayName": "Generic MQTT Motion Demo",
  "dataDriven": {
    "device": {
      "device": "Generic MQTT Motion Demo",
      "devType": "generic-machine",
      "defaultAssetCode": "GEN",
      "interpolationMs": 250
    },
    "motion": {
      "position_x": {
        "channel": "position_x",
        "fields": [
          "position_x"
        ],
        "mode": "absolute",
        "target": {
          "kind": "root"
        },
        "property": "position",
        "axis": "x",
        "space": "local",
        "scale": 1,
        "offset": 0,
        "invert": false,
        "min": -3,
        "max": 3,
        "smoothing": {
          "kind": "linear",
          "durationMs": 250
        }
      },
      "joint_angle_deg": {
        "channel": "joint_angle_deg",
        "fields": [
          "joint_angle_deg"
        ],
        "mode": "absolute",
        "target": {
          "kind": "node",
          "selector": "AccentPanel"
        },
        "property": "rotation",
        "axis": "z",
        "space": "local",
        "scale": 1,
        "offset": 0,
        "invert": false,
        "min": -60,
        "max": 60,
        "smoothing": {
          "kind": "linear",
          "durationMs": 250
        }
      },
      "operation_state": {
        "channel": "operation_state",
        "fields": [
          "operation_state"
        ],
        "mode": "state",
        "target": {
          "kind": "animation",
          "selector": "DoorPulse"
        },
        "scale": 1,
        "offset": 0,
        "invert": false,
        "actionMap": {
          "forward": "play",
          "reverse": "reverse",
          "fault": "play",
          "recovery": "play"
        },
        "animation": {
          "loop": false,
          "speed": 1
        }
      }
    },
    "fixedNodes": []
  }
}
